{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if success %}
      <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}</div>
    {% endif %}
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}</div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <div class="form-group">
          <label class="col-sm-2 control-label">{{ entry_status }}</label>
          <div class="col-sm-10">
            <div class="well well-sm" style="margin-bottom:10px;">
              <form action="{{ import_action }}" method="post" enctype="multipart/form-data" id="import-form" style="margin-bottom:10px;">
                <input type="hidden" name="import_action" value="1" />
                <div class="row">
                  <div class="col-sm-6">
                    <input type="file" name="import_file" class="form-control" accept=".txt,.json,.yaml,.yml,.conf" />
                  </div>
                  <div class="col-sm-2">
                    <button type="submit" class="btn btn-info">{{ button_import }}</button>
                  </div>
                  <div class="col-sm-12" style="margin-top:6px;">
                    <small class="text-muted">{{ help_import }}</small>
                  </div>
                </div>
              </form>
              <div class="row">
                <div class="col-sm-6">
                  <select id="new-product-tab-select" class="form-control">
                    <option value="0">- {{ entry_product_id }} -</option>
                    {% for product in products %}
                      <option value="{{ product.product_id }}">#{{ product.product_id }} - {{ product.name }}</option>
                    {% endfor %}
                  </select>
                </div>
                <div class="col-sm-2">
                  <button type="button" class="btn btn-default" id="open-product-tab-btn">{{ button_add_mapping }}</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <ul class="nav nav-tabs" id="product-tabs">
          {% for group in mapping_groups %}
            <li{% if loop.first %} class="active"{% endif %}><a href="#tab-product-{{ group.product_id }}" data-toggle="tab">#{{ group.product_id }} - {{ group.product_name }}</a></li>
          {% endfor %}
        </ul>

        <div class="tab-content" id="product-tab-content" style="margin-top:12px;">
          {% set mapping_row = 0 %}
          {% for group in mapping_groups %}
            <div class="tab-pane{% if loop.first %} active{% endif %}" id="tab-product-{{ group.product_id }}" data-product-id="{{ group.product_id }}">
              <form action="{{ action }}" method="post" enctype="multipart/form-data" class="form-horizontal product-form" id="form-product-{{ group.product_id }}">
                <input type="hidden" name="active_product_id" value="{{ group.product_id }}" />
                <input type="hidden" name="module_cyberpunks_variant_images_status" value="{{ module_cyberpunks_variant_images_status ? 1 : 0 }}" />
                <input type="hidden" name="module_cyberpunks_variant_images_payload" class="js-mappings-payload" value="" />
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
                  <div>
                    <a href="{{ export_url_base }}{{ group.product_id }}" class="btn btn-default"><i class="fa fa-download"></i> {{ button_export }}</a>
                    <button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
                  </div>
                  <div>
                    <button type="submit" name="delete_tab_action" value="1" class="btn btn-danger" onclick="return confirm('{{ text_confirm_delete_tab|e('js') }}');"><i class="fa fa-trash"></i> {{ button_delete_tab }}</button>
                  </div>
                </div>
                <div class="table-responsive">
                  <table class="table table-striped table-bordered table-hover">
                    <thead>
                      <tr>
                        <td class="text-left">{{ entry_signature }}<br><small>{{ help_signature }}</small></td>
                        <td class="text-left">{{ entry_image }}<br><small>{{ help_image }}</small></td>
                        <td class="text-left">{{ entry_mapping_status }}</td>
                        <td></td>
                      </tr>
                    </thead>
                    <tbody id="tbody-product-{{ group.product_id }}">
                      {% for mapping in group.mappings %}
                        <tr id="mapping-row-{{ mapping_row }}" data-product-id="{{ group.product_id }}" data-initial-pairs="{{ mapping.pairs_json|default('[]')|e('html_attr') }}">
                          <td>
                            <input type="hidden" name="module_cyberpunks_variant_images_mappings[{{ mapping_row }}][product_id]" value="{{ group.product_id }}" />
                            <input type="hidden" name="module_cyberpunks_variant_images_mappings[{{ mapping_row }}][option_value_signature]" value="{{ mapping.option_value_signature }}" class="js-signature-input" />
                            <input type="hidden" name="module_cyberpunks_variant_images_mappings[{{ mapping_row }}][pairs_json]" value="{{ mapping.pairs_json|default('[]')|e('html_attr') }}" class="js-pairs-json-input" />
                            <div class="js-pairs-wrap" data-row="{{ mapping_row }}"></div>
                            <div style="margin-top:8px;">
                              <button type="button" class="btn btn-default js-add-pair-btn" data-row="{{ mapping_row }}">{{ button_add_option_pair }}</button>
                            </div>
                            <small class="text-muted js-signature-preview">{{ mapping.option_value_signature }}</small>
                          </td>
                          <td><input type="text" name="module_cyberpunks_variant_images_mappings[{{ mapping_row }}][image]" value="{{ mapping.image }}" class="form-control" /></td>
                          <td>
                            <select name="module_cyberpunks_variant_images_mappings[{{ mapping_row }}][status]" class="form-control">
                              {% if mapping.status %}
                                <option value="1" selected="selected">{{ text_enabled }}</option>
                                <option value="0">{{ text_disabled }}</option>
                              {% else %}
                                <option value="1">{{ text_enabled }}</option>
                                <option value="0" selected="selected">{{ text_disabled }}</option>
                              {% endif %}
                            </select>
                          </td>
                          <td class="text-right"><button type="button" onclick="document.getElementById('mapping-row-{{ mapping_row }}').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>
                        </tr>
                        {% set mapping_row = mapping_row + 1 %}
                      {% endfor %}
                    </tbody>
                    <tfoot>
                      <tr>
                        <td colspan="3"></td>
                        <td class="text-right"><button type="button" class="btn btn-primary js-add-mapping-btn" data-product-id="{{ group.product_id }}"><i class="fa fa-plus-circle"></i></button></td>
                      </tr>
                    </tfoot>
                  </table>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;">
                  <div>
                    <a href="{{ export_url_base }}{{ group.product_id }}" class="btn btn-default"><i class="fa fa-download"></i> {{ button_export }}</a>
                    <button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
                  </div>
                  <div>
                    <button type="submit" name="delete_tab_action" value="1" class="btn btn-danger" onclick="return confirm('{{ text_confirm_delete_tab|e('js') }}');"><i class="fa fa-trash"></i> {{ button_delete_tab }}</button>
                  </div>
                </div>
              </form>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript"><!--
var mapping_row = {{ mapping_row|default(0) }};
var productOptionsHtml = '{% for product in products %}<option value="{{ product.product_id }}">#{{ product.product_id }} - {{ product.name|e('js') }}</option>{% endfor %}';
var optionDataUrl = '{{ option_data_url|replace({'&amp;': '&'})|e('js') }}';
var optionCache = {};
var moduleAction = '{{ action|replace({'&amp;': '&'})|e('js') }}';
var exportUrlBase = '{{ export_url_base|replace({'&amp;': '&'})|e('js') }}';
var moduleStatus = {{ module_cyberpunks_variant_images_status ? 1 : 0 }};
var productNameMap = { {% for product in products %}'{{ product.product_id }}': '{{ product.name|e('js') }}'{% if not loop.last %}, {% endif %}{% endfor %} };

function addMappingRow(productId) {
  var tbody = document.getElementById('tbody-product-' + productId);
  if (!tbody) return;

  var html = '';
  html += '<tr id="mapping-row-' + mapping_row + '" data-product-id="' + productId + '" data-initial-pairs="[]">';
  html += '  <td><input type="hidden" name="module_cyberpunks_variant_images_mappings[' + mapping_row + '][product_id]" value="' + productId + '" />';
  html += '      <input type="hidden" name="module_cyberpunks_variant_images_mappings[' + mapping_row + '][option_value_signature]" value="" class="js-signature-input" />';
  html += '      <input type="hidden" name="module_cyberpunks_variant_images_mappings[' + mapping_row + '][pairs_json]" value="[]" class="js-pairs-json-input" />';
  html += '      <div class="js-pairs-wrap" data-row="' + mapping_row + '"></div>';
  html += '      <div style="margin-top:8px;"><button type="button" class="btn btn-default js-add-pair-btn" data-row="' + mapping_row + '">{{ button_add_option_pair }}</button></div>';
  html += '      <small class="text-muted js-signature-preview"></small>';
  html += '  </td>';
  html += '  <td><input type="text" name="module_cyberpunks_variant_images_mappings[' + mapping_row + '][image]" value="" class="form-control" /></td>';
  html += '  <td><select name="module_cyberpunks_variant_images_mappings[' + mapping_row + '][status]" class="form-control"><option value="1" selected="selected">{{ text_enabled }}</option><option value="0">{{ text_disabled }}</option></select></td>';
  html += '  <td class="text-right"><button type="button" onclick="document.getElementById(\\\'mapping-row-' + mapping_row + '\\\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
  html += '</tr>';

  tbody.insertAdjacentHTML('beforeend', html);
  initMappingRow(mapping_row, []);
  mapping_row++;
}

function escapeHtml(value) {
  return String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function getRowEl(row) {
  return document.getElementById('mapping-row-' + row);
}

function loadProductOptions(productId) {
  var key = String(productId || 0);
  if (optionCache[key]) {
    return Promise.resolve(optionCache[key]);
  }

  if (!productId || Number(productId) <= 0) {
    optionCache[key] = [];
    return Promise.resolve([]);
  }

  return fetch(optionDataUrl + '&product_id=' + encodeURIComponent(productId))
    .then(function(response) { return response.json(); })
    .then(function(json) {
      optionCache[key] = Array.isArray(json.options) ? json.options : [];
      return optionCache[key];
    })
    .catch(function() {
      optionCache[key] = [];
      return [];
    });
}

function buildOptionSelect(options, selectedProductOptionId) {
  var html = '<option value="0">-</option>';
  options.forEach(function(option) {
    var selected = Number(option.product_option_id) === Number(selectedProductOptionId) ? ' selected="selected"' : '';
    html += '<option value="' + escapeHtml(option.product_option_id) + '"' + selected + '>' + escapeHtml(option.name) + '</option>';
  });
  return html;
}

function buildValueSelect(values, selectedProductOptionValueId) {
  var html = '<option value="0">-</option>';
  values.forEach(function(value) {
    var selected = Number(value.product_option_value_id) === Number(selectedProductOptionValueId) ? ' selected="selected"' : '';
    html += '<option value="' + escapeHtml(value.product_option_value_id) + '" data-option-value-id="' + escapeHtml(value.option_value_id) + '"' + selected + '>' + escapeHtml(value.name) + '</option>';
  });
  return html;
}

function findOption(options, productOptionId) {
  var found = null;
  options.forEach(function(option) {
    if (Number(option.product_option_id) === Number(productOptionId)) {
      found = option;
    }
  });
  return found;
}

function appendPairRow(row, options, pair) {
  var rowEl = getRowEl(row);
  if (!rowEl) return;

  var wrap = rowEl.querySelector('.js-pairs-wrap');
  if (!wrap) return;

  var productOptionId = pair && pair.product_option_id ? Number(pair.product_option_id) : 0;
  var option = findOption(options, productOptionId) || options[0] || null;
  var values = option ? option.values : [];
  var productOptionValueId = pair && pair.product_option_value_id ? Number(pair.product_option_value_id) : 0;

  var item = document.createElement('div');
  item.className = 'js-pair-item';
  item.style.marginBottom = '6px';

  item.innerHTML =
    '<div style="display:flex;gap:6px;align-items:center;">' +
      '<select class="form-control js-pair-option" style="min-width:220px;">' + buildOptionSelect(options, option ? option.product_option_id : 0) + '</select>' +
      '<select class="form-control js-pair-value" style="min-width:220px;">' + buildValueSelect(values, productOptionValueId) + '</select>' +
      '<button type="button" class="btn btn-danger js-remove-pair"><i class="fa fa-minus-circle"></i></button>' +
    '</div>';

  var optionSelect = item.querySelector('.js-pair-option');
  var valueSelect = item.querySelector('.js-pair-value');

  optionSelect.addEventListener('change', function() {
    var selectedOption = findOption(options, this.value);
    valueSelect.innerHTML = buildValueSelect(selectedOption ? selectedOption.values : [], 0);
    syncRowData(row);
  });

  valueSelect.addEventListener('change', function() {
    syncRowData(row);
  });

  item.querySelector('.js-remove-pair').addEventListener('click', function() {
    item.remove();
    syncRowData(row);
  });

  wrap.appendChild(item);
}

function syncRowData(row) {
  var rowEl = getRowEl(row);
  if (!rowEl) return;

  var pairs = [];
  var signatureIds = [];

  rowEl.querySelectorAll('.js-pair-item').forEach(function(item) {
    var optionSelect = item.querySelector('.js-pair-option');
    var valueSelect = item.querySelector('.js-pair-value');
    if (!optionSelect || !valueSelect) return;

    var productOptionId = Number(optionSelect.value || 0);
    var productOptionValueId = Number(valueSelect.value || 0);
    var selectedValueOption = valueSelect.options[valueSelect.selectedIndex];
    var optionValueId = selectedValueOption ? Number(selectedValueOption.getAttribute('data-option-value-id') || 0) : 0;

    if (!productOptionId || !productOptionValueId || !optionValueId) return;

    pairs.push({
      product_option_id: productOptionId,
      product_option_value_id: productOptionValueId,
      option_value_id: optionValueId
    });
    signatureIds.push(productOptionValueId);
  });

  signatureIds = Array.from(new Set(signatureIds)).sort(function(a, b) { return a - b; });
  var signature = signatureIds.join('-');

  var signatureInput = rowEl.querySelector('.js-signature-input');
  var pairsJsonInput = rowEl.querySelector('.js-pairs-json-input');
  var preview = rowEl.querySelector('.js-signature-preview');

  if (signatureInput) signatureInput.value = signature;
  if (pairsJsonInput) pairsJsonInput.value = JSON.stringify(pairs);
  if (preview) preview.textContent = signature;
}

function initMappingRow(row, initialPairs) {
  var rowEl = getRowEl(row);
  if (!rowEl) return;

  var addPairBtn = rowEl.querySelector('.js-add-pair-btn');
  var wrap = rowEl.querySelector('.js-pairs-wrap');
  var productId = Number(rowEl.getAttribute('data-product-id') || 0);
  if (!addPairBtn || !wrap || !productId) return;

  function rerenderPairs(pairs, appendEmptyWhenNone) {
    wrap.innerHTML = '';
    loadProductOptions(productId).then(function(options) {
      if (!options.length) {
        syncRowData(row);
        return;
      }

      if (pairs && pairs.length) {
        pairs.forEach(function(pair) {
          appendPairRow(row, options, pair);
        });
      } else if (appendEmptyWhenNone) {
        appendPairRow(row, options, null);
      }

      syncRowData(row);
    });
  }

  addPairBtn.addEventListener('click', function() {
    loadProductOptions(productId).then(function(options) {
      if (!options.length) return;
      appendPairRow(row, options, null);
      syncRowData(row);
    });
  });

  rerenderPairs(initialPairs || [], !(initialPairs && initialPairs.length));
}

document.querySelectorAll('tr[id^="mapping-row-"]').forEach(function(rowEl) {
  var row = Number(rowEl.id.replace('mapping-row-', ''));
  var initialPairs = [];
  try {
    initialPairs = JSON.parse(rowEl.getAttribute('data-initial-pairs') || '[]');
  } catch (e) {
    initialPairs = [];
  }
  initMappingRow(row, Array.isArray(initialPairs) ? initialPairs : []);
});

document.querySelectorAll('.js-add-mapping-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    addMappingRow(Number(this.getAttribute('data-product-id') || 0));
  });
});

function buildFormPayload(form) {
  var productIdInput = form.querySelector('input[name="active_product_id"]');
  var productId = Number(productIdInput ? productIdInput.value : 0);
  var payload = [];

  form.querySelectorAll('tr[id^="mapping-row-"]').forEach(function(rowEl) {
    var signatureInput = rowEl.querySelector('.js-signature-input');
    var pairsInput = rowEl.querySelector('.js-pairs-json-input');
    var imageInput = rowEl.querySelector('input[name*="[image]"]');
    var statusSelect = rowEl.querySelector('select[name*="[status]"]');

    var signature = signatureInput ? String(signatureInput.value || '').trim() : '';
    var image = imageInput ? String(imageInput.value || '').trim() : '';
    var pairsJson = pairsInput ? String(pairsInput.value || '[]') : '[]';
    var status = statusSelect ? Number(statusSelect.value || 0) : 0;

    if (!signature || !image) {
      return;
    }

    payload.push({
      product_id: productId,
      option_value_signature: signature,
      pairs_json: pairsJson,
      image: image,
      status: status ? 1 : 0
    });
  });

  return payload;
}

function bindFormSubmit(form) {
  if (!form || form.getAttribute('data-payload-bound') === '1') return;
  form.setAttribute('data-payload-bound', '1');

  form.addEventListener('submit', function() {
    var payloadInput = form.querySelector('.js-mappings-payload');
    if (!payloadInput) return;

    payloadInput.value = JSON.stringify(buildFormPayload(form));

    // Remove verbose per-row input names to avoid max_input_vars limits.
    form.querySelectorAll('tr[id^="mapping-row-"] input[name], tr[id^="mapping-row-"] select[name]').forEach(function(el) {
      el.removeAttribute('name');
    });
  });
}

document.querySelectorAll('form.product-form').forEach(bindFormSubmit);

document.getElementById('open-product-tab-btn').addEventListener('click', function() {
  var select = document.getElementById('new-product-tab-select');
  var productId = Number(select.value || 0);
  if (!productId) return;

  var tabId = 'tab-product-' + productId;
  var existingTabPane = document.getElementById(tabId);
  if (existingTabPane) {
    $('#product-tabs a[href="#' + tabId + '"]').tab('show');
    return;
  }

  var productName = productNameMap[String(productId)] || ('#' + productId);
  var navHtml = '<li><a href="#' + tabId + '" data-toggle="tab">#' + productId + ' - ' + escapeHtml(productName) + '</a></li>';
  document.getElementById('product-tabs').insertAdjacentHTML('beforeend', navHtml);

  var paneHtml = '' +
    '<div class="tab-pane" id="' + tabId + '" data-product-id="' + productId + '">' +
      '<form action="' + moduleAction + '" method="post" enctype="multipart/form-data" class="form-horizontal product-form" id="form-product-' + productId + '">' +
        '<input type="hidden" name="active_product_id" value="' + productId + '" />' +
        '<input type="hidden" name="module_cyberpunks_variant_images_status" value="' + moduleStatus + '" />' +
        '<input type="hidden" name="module_cyberpunks_variant_images_payload" class="js-mappings-payload" value="" />' +
        '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;"><div><a href="' + exportUrlBase + productId + '" class="btn btn-default"><i class="fa fa-download"></i> {{ button_export }}</a> <button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button></div><div><button type="submit" name="delete_tab_action" value="1" class="btn btn-danger" onclick="return confirm(\\\'{{ text_confirm_delete_tab|e('js') }}\\\');"><i class="fa fa-trash"></i> {{ button_delete_tab }}</button></div></div>' +
        '<div class="table-responsive">' +
          '<table class="table table-striped table-bordered table-hover">' +
            '<thead><tr>' +
              '<td class="text-left">{{ entry_signature }}<br><small>{{ help_signature }}</small></td>' +
              '<td class="text-left">{{ entry_image }}<br><small>{{ help_image }}</small></td>' +
              '<td class="text-left">{{ entry_mapping_status }}</td>' +
              '<td></td>' +
            '</tr></thead>' +
            '<tbody id="tbody-product-' + productId + '"></tbody>' +
            '<tfoot><tr><td colspan="3"></td><td class="text-right"><button type="button" class="btn btn-primary js-add-mapping-btn" data-product-id="' + productId + '"><i class="fa fa-plus-circle"></i></button></td></tr></tfoot>' +
          '</table>' +
        '</div>' +
        '<div style="display:flex;justify-content:space-between;align-items:center;"><div><a href="' + exportUrlBase + productId + '" class="btn btn-default"><i class="fa fa-download"></i> {{ button_export }}</a> <button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button></div><div><button type="submit" name="delete_tab_action" value="1" class="btn btn-danger" onclick="return confirm(\\\'{{ text_confirm_delete_tab|e('js') }}\\\');"><i class="fa fa-trash"></i> {{ button_delete_tab }}</button></div></div>' +
      '</form>' +
    '</div>';
  document.getElementById('product-tab-content').insertAdjacentHTML('beforeend', paneHtml);

  var newAddBtn = document.querySelector('#' + tabId + ' .js-add-mapping-btn');
  if (newAddBtn) {
    newAddBtn.addEventListener('click', function() {
      addMappingRow(Number(this.getAttribute('data-product-id') || 0));
    });
    addMappingRow(productId);
  }

  bindFormSubmit(document.getElementById('form-product-' + productId));

  $('#product-tabs a[href="#' + tabId + '"]').tab('show');
});
//--></script>
{{ footer }}
