{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-cyberpunks-option-fields" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-cyberpunks-option-fields" class="form-horizontal">
          <table id="cyberpunks-fields" class="table table-striped table-bordered table-hover">
            <thead>
              <tr>
                <td class="text-left">{{ entry_key }}</td>
                <td class="text-left">{{ entry_label }}</td>
                <td class="text-left">{{ entry_type }}</td>
                <td class="text-left">{{ entry_scope }}</td>
                <td class="text-right">{{ entry_sort_order }}</td>
                <td class="text-left">{{ entry_status }}</td>
                <td></td>
              </tr>
            </thead>
            <tbody>
              {% set field_row = 0 %}
              {% for field in fields %}
              <tr id="field-row-{{ field_row }}">
                <td class="text-left"><input type="text" name="cyberpunks_custom_fields[{{ field_row }}][field_key]" value="{{ field.field_key is defined ? field.field_key : '' }}" class="form-control" /></td>
                <td class="text-left"><input type="text" name="cyberpunks_custom_fields[{{ field_row }}][label]" value="{{ field.label is defined ? field.label : '' }}" class="form-control" /></td>
                <td class="text-left">
                  <select name="cyberpunks_custom_fields[{{ field_row }}][field_type]" class="form-control">
                    <option value="text" {% if field.field_type is not defined or field.field_type == 'text' %}selected="selected"{% endif %}>{{ text_text }}</option>
                    <option value="textarea" {% if field.field_type is defined and field.field_type == 'textarea' %}selected="selected"{% endif %}>{{ text_textarea }}</option>
                    <option value="boolean" {% if field.field_type is defined and field.field_type == 'boolean' %}selected="selected"{% endif %}>{{ text_boolean }}</option>
                  </select>
                </td>
                <td class="text-left">
                  <select name="cyberpunks_custom_fields[{{ field_row }}][scope]" class="form-control">
                    <option value="option" {% if field.scope is defined and field.scope == 'option' %}selected="selected"{% endif %}>{{ text_scope_option }}</option>
                    <option value="option_value" {% if field.scope is not defined or field.scope == 'option_value' %}selected="selected"{% endif %}>{{ text_scope_option_value }}</option>
                  </select>
                </td>
                <td class="text-right"><input type="text" name="cyberpunks_custom_fields[{{ field_row }}][sort_order]" value="{{ field.sort_order is defined ? field.sort_order : 0 }}" class="form-control" /></td>
                <td class="text-left">
                  <select name="cyberpunks_custom_fields[{{ field_row }}][status]" class="form-control">
                    <option value="1" {% if field.status is not defined or field.status %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                    <option value="0" {% if field.status is defined and not field.status %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                  </select>
                </td>
                <td class="text-right"><button type="button" onclick="$('#field-row-{{ field_row }}').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>
              </tr>
              {% set field_row = field_row + 1 %}
              {% endfor %}
            </tbody>
            <tfoot>
              <tr>
                <td colspan="6"></td>
                <td class="text-right"><button type="button" onclick="addCustomField();" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus-circle"></i></button></td>
              </tr>
            </tfoot>
          </table>
        </form>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript"><!--
var field_row = {{ field_row }};

function addCustomField() {
  var html = '';
  html += '<tr id="field-row-' + field_row + '">';
  html += '  <td class="text-left"><input type="text" name="cyberpunks_custom_fields[' + field_row + '][field_key]" value="" class="form-control" /></td>';
  html += '  <td class="text-left"><input type="text" name="cyberpunks_custom_fields[' + field_row + '][label]" value="" class="form-control" /></td>';
  html += '  <td class="text-left"><select name="cyberpunks_custom_fields[' + field_row + '][field_type]" class="form-control"><option value="text">{{ text_text }}</option><option value="textarea">{{ text_textarea }}</option><option value="boolean">{{ text_boolean }}</option></select></td>';
  html += '  <td class="text-left"><select name="cyberpunks_custom_fields[' + field_row + '][scope]" class="form-control"><option value="option">{{ text_scope_option }}</option><option value="option_value" selected="selected">{{ text_scope_option_value }}</option></select></td>';
  html += '  <td class="text-right"><input type="text" name="cyberpunks_custom_fields[' + field_row + '][sort_order]" value="0" class="form-control" /></td>';
  html += '  <td class="text-left"><select name="cyberpunks_custom_fields[' + field_row + '][status]" class="form-control"><option value="1">{{ text_enabled }}</option><option value="0">{{ text_disabled }}</option></select></td>';
  html += '  <td class="text-right"><button type="button" onclick="$(\'#field-row-' + field_row + '\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
  html += '</tr>';

  $('#cyberpunks-fields tbody').append(html);
  field_row++;
}
//--></script>
{{ footer }}
