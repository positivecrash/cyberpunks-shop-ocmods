<?xml version="1.0" encoding="utf-8"?>
<modification>
	<name>Cyberpunks Shop Language Overrides</name>
	<code>cyberpunks_shop_language_overrides</code>
	<version>1.2.0</version>
	<author>positivecrash</author>
	<description>Admin-managed language overrides for checkout cart strings.</description>

	<file path="catalog/controller/checkout/cart.php">
		<operation error="skip">
			<search><![CDATA[$this->load->language('checkout/cart');]]></search>
			<add position="after"><![CDATA[
		$cp_language_overrides = $this->config->get('module_cyberpunks_language_overrides_map');
		if (is_array($cp_language_overrides)) {
			foreach ($cp_language_overrides as $cp_language_key => $cp_language_value) {
				if ($cp_language_value !== '') {
					$this->language->set($cp_language_key, $cp_language_value);
				}
			}
		}
			]]></add>
		</operation>

		<operation error="skip">
			<search><![CDATA[$data['totals'] = array();]]></search>
			<add position="after"><![CDATA[
			$cp_total_label_overrides = $this->config->get('module_cyberpunks_language_overrides_total_labels');
			if (!is_array($cp_total_label_overrides)) {
				$cp_total_label_overrides = array();
			}
			]]></add>
		</operation>

		<operation error="skip">
			<search><![CDATA[$data['totals'][] = array(]]></search>
			<add position="before"><![CDATA[
				$cp_total_code = isset($total['code']) ? (string)$total['code'] : '';
				$cp_total_title = $total['title'];
				if ($cp_total_code !== '' && !empty($cp_total_label_overrides[$cp_total_code])) {
					$cp_total_title = $cp_total_label_overrides[$cp_total_code];
				}
			]]></add>
		</operation>

		<operation error="skip">
			<search><![CDATA['title' => $total['title'],]]></search>
			<add position="replace"><![CDATA['title' => $cp_total_title,]]></add>
		</operation>
	</file>
</modification>
