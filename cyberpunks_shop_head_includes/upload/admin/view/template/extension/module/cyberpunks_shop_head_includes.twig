  html += '    <div class="form-group"><label class="col-sm-2 control-label">{{ entry_js }}</label><div class="col-sm-10"><textarea name="cyberpunks_shop_head_includes_rules[' + rule_row + '][js]" rows="4" class="form-control"></textarea><div class="help-block">{{ help_js }}</div></div></div>';
  html += '    <div class="form-group"><label class="col-sm-2 control-label">{{ entry_css }}</label><div class="col-sm-10"><textarea name="cyberpunks_shop_head_includes_rules[' + rule_row + '][css]" rows="4" class="form-control"></textarea><div class="help-block">{{ help_css }}</div></div></div>';
  html += '    <div class="form-group"><label class="col-sm-2 control-label">{{ entry_js_exclude }}</label><div class="col-sm-10"><textarea name="cyberpunks_shop_head_includes_rules[' + rule_row + '][js_exclude]" rows="4" class="form-control"></textarea><div class="help-block">{{ help_js_exclude }}</div></div></div>';
  html += '    <div class="form-group"><label class="col-sm-2 control-label">{{ entry_css_exclude }}</label><div class="col-sm-10"><textarea name="cyberpunks_shop_head_includes_rules[' + rule_row + '][css_exclude]" rows="4" class="form-control"></textarea><div class="help-block">{{ help_css_exclude }}</div></div></div>';
  html += '    <div class="form-group"><label class="col-sm-2 control-label">{{ entry_rule_status }}</label><div class="col-sm-8"><select name="cyberpunks_shop_head_includes_rules[' + rule_row + '][status]" class="form-control"><option value="1" selected="selected">{{ text_enabled }}</option><option value="0">{{ text_disabled }}</option></select></div><div class="col-sm-2 text-right"><button type="button" class="btn btn-danger" onclick="$(\'#rule-' + rule_row + '\').remove();"><i class="fa fa-trash"></i></button></div></div>';
  html += '  </div>';
  html += '</div>';

  $('#rules').append(html);
  rule_row++;
});
//--></script>
{{ footer }}
